<core:FragmentDefinition
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  core:require="{ handler: 'benchlist/skillwisesplit/ext/handler/SkillSummaryHandlers' }">

  <Dialog id="_IDGenDialog1"
    title="Employee Details"
    contentWidth="70%"
    contentHeight="420px"
    draggable="true"
    resizable="true">

    <content>
      <Table
        id="employeeTable"
        growing="true"
        growingScrollToLoad="true">
        <columns>
          <Column id="_IDGenColumn" width="5rem"><Text id="_IDGenText" text="DC"/></Column>
          <Column id="_IDGenColumn1" width="5rem"><Text id="_IDGenText1" text="Employee Number"/></Column>
          <Column id="_IDGenColumn2" width="8rem"><Text id="_IDGenText2" text="Name"/></Column>
          <Column id="_IDGenColumn3" width="7rem"><Text id="_IDGenText3" text="Cost Center"/></Column>
          <Column id="_IDGenColumn4" width="5rem"><Text id="_IDGenText4" text="Platform"/></Column>
          <Column id="_IDGenColumn5" width="8rem"><Text id="_IDGenText5" text="Role"/></Column>
          <Column id="_IDGenColumn6" width="5rem"><Text id="_IDGenText6" text="Primary Skills"/></Column>
          <Column id="_IDGenColumn7" width="4rem"><Text id="_IDGenText7" text="Availability"/></Column>
          <Column id="_IDGenColumn8" width="8rem"><Text id="_IDGenText8" text="Pillar Lead"/></Column>
          <Column id="_IDGenColumn9" width="3rem"><Text id="_IDGenText9" text="Bench Status"/></Column>
          <Column id="_IDGenColumn10" width="6rem"><Text id="_IDGenText10" text="Resource Proposal Status"/></Column>
          <Column id="_IDGenColumn11" width="15rem"><Text id="_IDGenText11" text="Comment"/></Column>
        </columns>
      </Table>
    </content>

    <endButton>
      <Button id="_IDGenButton" text="Close" press="handler.onDialogClose"/>
    </endButton>
  </Dialog>
</core:FragmentDefinition>
